{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "build": {
    "env": {
      "NEXT_PUBLIC_DISABLE_AUTH": "true"
    }
  },
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}